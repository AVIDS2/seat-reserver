# Copy this file to .env on the Debian 12 VPS and fill in current values.
# Do not commit real tokens or account identifiers.

BOOK_TOKEN=<TOKEN_FROM_REQABLE>

# Optional normal login refresh. If BOOK_TOKEN expires, the script can call
# /rest/auth with your own account and write the refreshed token back to .env.
BOOK_USERNAME=<USERNAME>
BOOK_PASSWORD=<PASSWORD>
BOOK_AUTO_REFRESH_TOKEN=true
BOOK_PERSIST_REFRESHED_TOKEN=true

# Seat priority. 197 is 44号.
BOOK_PRIMARY_SEAT=197
BOOK_BACKUP_SEATS=211

# Legacy single target fallback if BOOK_TIME_CANDIDATES is not set.
BOOK_START_TIME=840
BOOK_END_TIME=1320

# Candidate time ranges, expressed as minutes after 00:00.
# 840-1320 = 14:00-22:00, 780-1260 = 13:00-21:00,
# 900-1320 = 15:00-22:00
BOOK_TIME_CANDIDATES=840-1320,780-1260,900-1320

# Keep attempts bounded to avoid high-frequency requests.
BOOK_MAX_ATTEMPTS=6
BOOK_ATTEMPT_DELAY_SECONDS=1.2
BOOK_TIMEOUT_SECONDS=8

# Optional. Leave empty unless the normal client request requires replaying it.
# This script does not generate or bypass HMAC signatures.
BOOK_HMAC_REQUEST_KEY=

BOOK_API_URL=https://leosys.cn/cczukaoyan/rest/v2/freeBook
BOOK_AUTH_URL=https://leosys.cn/cczukaoyan/rest/auth
BOOK_USER_URL=https://leosys.cn/cczukaoyan/rest/v2/user
